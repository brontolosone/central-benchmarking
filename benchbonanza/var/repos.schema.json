{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "repos"
    ],
    "properties": {
        "repos": {
            "type": "object",
            "description": "Map of repository monikers to repository configuration",
            "patternProperties": {
                "^[a-z0-9_-]{1,8}$": {
                    "type": "object",
                    "required": [
                        "url"
                    ],
                    "properties": {
                        "url": {
                            "type": "string",
                            "format": "uri",
                            "description": "Git repository URL"
                        },
                        "paused": {
                            "type": "boolean",
                            "description": "Whether the repository is paused",
                            "default": false
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}
